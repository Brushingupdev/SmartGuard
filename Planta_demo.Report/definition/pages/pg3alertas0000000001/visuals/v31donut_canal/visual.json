{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.8.0/schema.json",
  "name": "v31donut_canal",
  "position": { "x": 20, "y": 120, "z": 2000, "width": 400, "height": 280 },
  "visual": {
    "visualType": "donutChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": { "Column": { "Expression": { "SourceRef": { "Entity": "pbi_alert_logs" } }, "Property": "channel" } },
              "queryRef": "pbi_alert_logs.channel", "nativeQueryRef": "channel", "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": { "Column": { "Expression": { "SourceRef": { "Entity": "pbi_alert_logs" } }, "Property": "id" } },
              "queryRef": "Count of pbi_alert_logs.id", "nativeQueryRef": "id"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}

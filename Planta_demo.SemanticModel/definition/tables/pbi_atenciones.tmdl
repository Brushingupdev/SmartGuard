table pbi_atenciones
	lineageTag: 29212573-1633-4507-b776-1d81a006b286

	/// Total de registros en el período seleccionado
	measure Total_Atenciones = COUNTROWS('pbi_atenciones')
		formatString: 0
		lineageTag: m001-total-atenciones

	/// Excluye transporte propio
	measure Atenciones_ProvCli =
			CALCULATE(
			    COUNTROWS('pbi_atenciones'),
			    'pbi_atenciones'[tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: m002-atenciones-provcli

	/// Atenciones con demora registrada (excluye propios)
	measure Con_Demora =
			CALCULATE(
			    COUNTROWS('pbi_atenciones'),
			    'pbi_atenciones'[es_demora] = 1,
			    'pbi_atenciones'[tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: m003-con-demora

	/// % de atenciones con demora
	measure Pct_Demora = DIVIDE(COALESCE([Con_Demora], 0), COALESCE([Atenciones_ProvCli], 0), 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: m004-pct-demora

	/// Promedio de espera en minutos (excluye vacíos y propios)
	measure Espera_Promedio =
			CALCULATE(
			    AVERAGE('pbi_atenciones'[espera_min]),
			    'pbi_atenciones'[espera_min] > 0,
			    'pbi_atenciones'[tipo] <> "Propio"
			)
		formatString: 0.0
		lineageTag: m005-espera-promedio

	/// Caso más extremo del período
	measure Espera_Maxima =
			CALCULATE(
			    MAX('pbi_atenciones'[espera_min]),
			    'pbi_atenciones'[tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: m006-espera-maxima

	/// A tiempo: < 30 min
	measure Seg_Menos30 =
			CALCULATE(
			    COUNTROWS('pbi_atenciones'),
			    'pbi_atenciones'[segmento_espera] = "🟢 < 30 min",
			    'pbi_atenciones'[tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: m007-seg-menos30

	/// Moderado: 30–45 min
	measure Seg_30_45 =
			CALCULATE(
			    COUNTROWS('pbi_atenciones'),
			    'pbi_atenciones'[segmento_espera] = "🟡 30-45 min",
			    'pbi_atenciones'[tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: m008-seg-3045

	/// Alto: 45–90 min
	measure Seg_45_90 =
			CALCULATE(
			    COUNTROWS('pbi_atenciones'),
			    'pbi_atenciones'[segmento_espera] = "🟠 45-90 min",
			    'pbi_atenciones'[tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: m009-seg-4590

	/// Crítico: > 90 min
	measure Seg_Mas90 =
			CALCULATE(
			    COUNTROWS('pbi_atenciones'),
			    'pbi_atenciones'[segmento_espera] = "🔴 > 90 min",
			    'pbi_atenciones'[tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: m010-seg-mas90

	measure Pct_Menos30 = DIVIDE([Seg_Menos30], [Atenciones_ProvCli], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: m011-pct-menos30

	measure Pct_30_45 = DIVIDE([Seg_30_45], [Atenciones_ProvCli], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: m012-pct-3045

	measure Pct_45_90 = DIVIDE([Seg_45_90], [Atenciones_ProvCli], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: m013-pct-4590

	measure Pct_Mas90 = DIVIDE([Seg_Mas90], [Atenciones_ProvCli], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: m014-pct-mas90

	/// Score ponderado de criticidad (para ranking de plantas/empresas)
	measure Score_Critico = [Seg_45_90] * 2 + [Seg_Mas90] * 4
		formatString: 0
		lineageTag: m015-score-critico

	/// Motivo de demora más frecuente en el período
	measure Top_Motivo =
			VAR TopTable =
			    TOPN(1,
			        SUMMARIZE(
			            FILTER('pbi_atenciones', 'pbi_atenciones'[espera_min] > 45 && 'pbi_atenciones'[tipo] <> "Propio"),
			            'pbi_atenciones'[motivo_demora],
			            "cnt", COUNTROWS('pbi_atenciones')
			        ),
			        [cnt], DESC
			    )
			RETURN MAXX(TopTable, 'pbi_atenciones'[motivo_demora])
		lineageTag: m016-top-motivo

	/// Variación vs mes anterior
	measure Var_Mes_Anterior =
			VAR actual = [Atenciones_ProvCli]
			VAR anterior = CALCULATE(
			    [Atenciones_ProvCli],
			    DATEADD('Calendario'[Date], -1, MONTH)
			)
			RETURN DIVIDE(actual - anterior, anterior, 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: m017-var-mes-anterior

	/// Variación del % de demora vs mes anterior (positivo = empeoró)
	measure Var_Pct_Demora =
			VAR actual = [Pct_Demora]
			VAR anterior = CALCULATE(
			    [Pct_Demora],
			    DATEADD('Calendario'[Date], -1, MONTH)
			)
			RETURN actual - anterior
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: m018-var-pct-demora


	partition Tbl_Atenciones = m
		mode: import
		source =
				let
				    ApiKey  = "sb_publishable_Be7cdcOHa7jACzqMvLgVZw_Fxr4JRJa",
				    Url     = "https://vjmcyriwwkimygubsimg.supabase.co/rest/v1/rpc/pbi_atenciones",
				    Origen  = Json.Document(Web.Contents(Url, [
				        Headers = [#"apikey" = ApiKey, #"Content-Type" = "application/json"]
				    ])),
				    ToTable = Table.FromList(Origen, Splitter.SplitByNothing(), null, null, ExtraValues.Error),
				    Expanded = Table.ExpandRecordColumn(ToTable, "Column1", {
				        "id","fecha","h_registro","h_atencion","h_dev_docs",
				        "razon_social","empresa","planta","tipo","tipo_operacion",
				        "responsable","agente","espera_min","tiempo_total_min",
				        "segmento_espera","es_demora","motivo_demora","observacion",
				        "anio","mes_num","company_id"
				    }),
				    Typed = Table.TransformColumnTypes(Expanded, {
				        {"id", Int64.Type}, {"fecha", type date},
				        {"espera_min", Int64.Type}, {"tiempo_total_min", Int64.Type},
				        {"es_demora", Int64.Type}, {"anio", Int64.Type}, {"mes_num", Int64.Type}
				    }),
				    AddMesNombre  = Table.AddColumn(Typed, "mes_nombre", each Date.ToText([fecha], "MMM", "es-PE"), type text),
				    AddSemana     = Table.AddColumn(AddMesNombre, "semana", each Date.WeekOfYear([fecha]), Int64.Type),
				    AddDiaSemana  = Table.AddColumn(AddSemana, "dia_semana", each Date.ToText([fecha], "ddd", "es-PE"), type text),
				    Renamed = Table.RenameColumns(AddDiaSemana, {
				        {"id","ID"}, {"fecha","Fecha"}, {"h_registro","H_Registro"},
				        {"h_atencion","H_Atencion"}, {"h_dev_docs","H_Dev_Docs"},
				        {"razon_social","Razon_Social"}, {"empresa","Empresa"}, {"planta","Planta"},
				        {"tipo","Tipo"}, {"tipo_operacion","Tipo_Operacion"},
				        {"responsable","Responsable"}, {"agente","Agente"},
				        {"espera_min","Espera_Min"}, {"tiempo_total_min","Tiempo_Total_Min"},
				        {"segmento_espera","Segmento_Espera"}, {"es_demora","Es_Demora"},
				        {"motivo_demora","Motivo_Demora"}, {"observacion","Observacion"},
				        {"anio","Año"}, {"mes_num","Mes_Num"},
				        {"mes_nombre","Mes_Nombre"}, {"semana","Semana"},
				        {"dia_semana","Dia_Semana"}, {"company_id","Company_ID"}
				    }),
				    Resultado = Table.TransformColumnTypes(Renamed, {
				        {"Planta", type text}, {"Razon_Social", type text}, {"Empresa", type text},
				        {"Tipo", type text}, {"Tipo_Operacion", type text}, {"Responsable", type text},
				        {"Agente", type text}, {"Segmento_Espera", type text}, {"Motivo_Demora", type text},
				        {"Observacion", type text}, {"Mes_Nombre", type text}, {"Dia_Semana", type text},
				        {"H_Registro", type time}, {"H_Atencion", type time}, {"H_Dev_Docs", type time}
				    })
				in
				    Resultado

	annotation PBI_ResultType = Table


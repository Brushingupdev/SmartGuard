table Tbl_Atenciones
	lineageTag: c1e22e0a-7604-4eb3-ae29-0788ab0630bc

	/// Total de registros en el período seleccionado
	measure Total_Atenciones = COUNTROWS('Tbl_Atenciones')
		formatString: 0
		lineageTag: 86cddd66-297f-4037-874b-9f8072d798f7

	/// Excluye transporte propio
	measure Atenciones_ProvCli =
			CALCULATE(
			    COUNTROWS('Tbl_Atenciones'),
			    'Tbl_Atenciones'[Tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: fd1eed3c-4062-4988-aab1-4c39da1aa7d3

	/// Atenciones donde espera > 0 con demora registrada
	measure Con_Demora =
			CALCULATE(
			    COUNTROWS('Tbl_Atenciones'),
			    'Tbl_Atenciones'[Es_Demora] = 1,
			    'Tbl_Atenciones'[Tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: f09d98a7-f98b-49d3-bd30-620c26eb703c

	/// Formato: Porcentaje en Power BI
	measure Pct_Demora = DIVIDE(COALESCE([Con_Demora], 0), COALESCE([Atenciones_ProvCli], 0), 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 71016c3f-4d7f-4cf4-bf70-6166ad9bb94d

	/// Promedio en minutos, excluye vacíos y propios
	measure Espera_Promedio =
			CALCULATE(
			    AVERAGE('Tbl_Atenciones'[Espera_Min]),
			    'Tbl_Atenciones'[Espera_Min] > 0,
			    'Tbl_Atenciones'[Tipo] <> "Propio"
			)
		formatString: 0.0
		lineageTag: 06e468b1-60e5-46d3-89d7-7de16d017fa0

	/// Caso más extremo del período
	measure Espera_Maxima =
			CALCULATE(
			    MAX('Tbl_Atenciones'[Espera_Min]),
			    'Tbl_Atenciones'[Tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: 5596e35b-55ea-4014-8da7-c418f52d1fc0

	/// Atenciones excelentes
	measure Seg_Menos30 =
			CALCULATE(
			    COUNTROWS('Tbl_Atenciones'),
			    'Tbl_Atenciones'[Segmento_Espera] = "🟢 < 30 min",
			    'Tbl_Atenciones'[Tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: ac26b8a9-2fd8-453f-aef4-3ba4e02f1aad

	/// Atenciones aceptables
	measure Seg_30_45 =
			CALCULATE(
			    COUNTROWS('Tbl_Atenciones'),
			    'Tbl_Atenciones'[Segmento_Espera] = "🟡 30-45 min",
			    'Tbl_Atenciones'[Tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: 52fee95b-a396-477a-b4ac-08526900321a

	/// Atenciones críticas
	measure Seg_45_90 =
			CALCULATE(
			    COUNTROWS('Tbl_Atenciones'),
			    'Tbl_Atenciones'[Segmento_Espera] = "🟠 45-90 min",
			    'Tbl_Atenciones'[Tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: 511c0e29-0b3d-40b9-ad11-c907c454930c

	/// Atenciones muy críticas
	measure Seg_Mas90 =
			CALCULATE(
			    COUNTROWS('Tbl_Atenciones'),
			    'Tbl_Atenciones'[Segmento_Espera] = "🔴 > 90 min",
			    'Tbl_Atenciones'[Tipo] <> "Propio"
			)
		formatString: 0
		lineageTag: e2885cc3-a898-4ec7-bb7a-8bcd46205991

	/// Formato porcentaje
	measure Pct_Menos30 = DIVIDE([Seg_Menos30], [Atenciones_ProvCli], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 4b40c973-f72e-4e3f-b31b-eb7b82abe062

	/// Formato porcentaje
	measure Pct_30_45 = DIVIDE([Seg_30_45], [Atenciones_ProvCli], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: a73350a5-e741-400a-b684-14142b1ab84c

	/// Formato porcentaje
	measure Pct_45_90 = DIVIDE([Seg_45_90], [Atenciones_ProvCli], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 06e0859e-870b-4d93-baf2-09e1c2e13f02

	/// Formato porcentaje
	measure Pct_Mas90 = DIVIDE([Seg_Mas90], [Atenciones_ProvCli], 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 94952f79-a9ed-45c9-beb0-fb7deefe991b

	/// Score ponderado para ranking de criticidad
	measure Score_Critico = [Seg_45_90] * 2 + [Seg_Mas90] * 4
		formatString: 0
		lineageTag: 9289d429-7f47-4391-9ace-e155ddce3ae7

	/// Motivo más frecuente en segmentos críticos
	measure Top_Motivo = ```
			VAR TopTable = 
			    TOPN(1,
			        SUMMARIZE(
			            FILTER('Tbl_Atenciones', 'Tbl_Atenciones'[Espera_Min] > 45 && 'Tbl_Atenciones'[Tipo] <> "Propio"),
			            'Tbl_Atenciones'[Motivo_Demora],
			            "cnt", COUNTROWS('Tbl_Atenciones')
			        ),
			        [cnt], DESC
			    )
			RETURN MAXX(TopTable, 'Tbl_Atenciones'[Motivo_Demora])
			```
		lineageTag: 29e295b6-c842-4e73-8d07-16fe3587989d

	/// Requiere tabla Calendario conectada
	measure Var_Mes_Anterior =
			VAR actual = [Atenciones_ProvCli]
			VAR anterior = CALCULATE(
			    [Atenciones_ProvCli],
			    DATEADD('Calendario'[Date], -1, MONTH)
			)
			RETURN DIVIDE(actual - anterior, anterior, 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: f1d2e683-da93-44e1-a4a5-89846708e4cc

	/// Positivo = empeoró, Negativo = mejoró
	measure Var_Pct_Demora =
			VAR actual = [Pct_Demora]
			VAR anterior = CALCULATE(
			    [Pct_Demora],
			    DATEADD('Calendario'[Date], -1, MONTH)
			)
			RETURN actual - anterior
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e3f30996-6573-408f-8887-f2417b21ce68


# ─────────────────────────────────────────────────────────────
# SmartGuard — Variables de entorno
# Copiar a .env.local y completar con tus valores
# ─────────────────────────────────────────────────────────────

# ── Supabase (requerido) ─────────────────────────────────────
# Obtener en: https://supabase.com/dashboard → Project Settings → API

# URL pública del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon key (segura para client-side, protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (SOLO server-side, bypass RLS — NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Upstash Redis (requerido para rate limiting) ─────────────
# Obtener en: https://console.upstash.com

UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── Resend (requerido para alertas por email) ────────────────
# Obtener en: https://resend.com/api-keys

RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Sentry (opcional, para error tracking) ───────────────────
# Obtener en: https://sentry.io → Project Settings → Client Keys

SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Supabase Webhook Secret (opcional, para webhooks) ────────
# Configurar en: Supabase Dashboard → Authentication → Webhooks

SUPABASE_WEBHOOK_SECRET=tu_webhook_secret_aqui

# ── Opcional ─────────────────────────────────────────────────

# URL base para links en emails (default: auto-detect desde request)
# NEXT_PUBLIC_APP_URL=https://smartguard.io
